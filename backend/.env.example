PORT=3000
NODE_ENV=development

# Database Configuration
# Make sure to update the DB_HOST, DB_USER, and DB_PASSWORD to match your local PostgreSQL setup
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=appointment_rs
DB_USER=postgres
DB_PASSWORD=root

# JWT Configuration
# In production, change these to strong random strings
JWT_ACCESS_SECRET=supersecretaccesskey123
JWT_REFRESH_SECRET=supersecretrefreshkey123
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
